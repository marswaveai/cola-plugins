{
  "name": "cola-plugins",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "build": "pnpm -r --filter './plugins/*' run build",
    "typecheck": "pnpm -r --filter './plugins/*' run typecheck",
    "build:registry": "tsx scripts/build-registry.ts",
    "test": "vitest run",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "oxfmt": "^0.42.0",
    "oxlint": "^1.67.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
