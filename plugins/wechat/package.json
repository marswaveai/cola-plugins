{
  "name": "cola-plugin-wechat",
  "version": "0.2.0",
  "description": "WeChat channel plugin for Cola",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "cola": {
    "plugin": {
      "id": "wechat",
      "entry": "./dist/index.js",
      "minSdkVersion": "0.5.0"
    },
    "channel": {
      "label": "WeChat",
      "description": "WeChat messaging channel via iLink bot protocol",
      "aliases": ["wx"],
      "docsPath": "/channels/wechat"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@marswave/cola-plugin-sdk": "^0.0.1",
    "qrcode-terminal": "0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "silk-wasm": "^3.7.1",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22"
  }
}
