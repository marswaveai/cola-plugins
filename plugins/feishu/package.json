{
  "name": "cola-plugin-feishu",
  "version": "0.1.1",
  "description": "Feishu/Lark channel plugin for Cola",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "cola": {
    "plugin": {
      "id": "feishu",
      "entry": "./dist/index.js"
    },
    "channel": {
      "label": "Feishu",
      "description": "Feishu/Lark messaging via official bot API",
      "iconUrl": "https://www.feishu.cn/favicon.ico",
      "aliases": ["lark"],
      "docsPath": "/channels/feishu"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@marswave/cola-plugin-sdk": "^0.0.1",
    "@larksuiteoapi/node-sdk": "^1.60.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22"
  }
}
